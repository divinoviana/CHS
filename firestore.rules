
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTeacher() {
      return isAuthenticated() && 
        (request.auth.token.email == 'filosofia@frederico.edu.br' ||
         request.auth.token.email == 'geografia@frederico.edu.br' ||
         request.auth.token.email == 'historia@frederico.edu.br' ||
         request.auth.token.email == 'sociologia@frederico.edu.br');
    }

    function isSuper() {
      return isAuthenticated() && request.auth.token.email == "divinoviana@gmail.com";
    }

    function isDocAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/students/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      // Ordem importa: checks rápidos primeiro para evitar get() desnecessário
      return isSuper() || isTeacher() || isDocAdmin();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (data.role == 'student' || data.role == 'admin') &&
             data.grade is string && data.school_class is string;
    }

    function isValidMessage(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.sender_id == request.auth.uid &&
             (data.subject == null || (data.subject is string && data.subject.size() < 50));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /students/{studentId} {
      allow read: if isAuthenticated();
      // Proteção contra escalação de privilégios: apenas admin cria outros admins.
      // Usuários comuns só podem criar seu próprio perfil como 'student'.
      allow create: if isAuthenticated() && isValidStudent(request.resource.data) && 
                    (isAdmin() || (isOwner(studentId) && request.resource.data.role == 'student'));
      allow update: if isAuthenticated() && isValidStudent(request.resource.data) && 
                    (isAdmin() || (isOwner(studentId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.student_id || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.student_id || isAdmin());
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      // Regra de leitura solicitada:
      // 1. Admin tem acesso total.
      // 2. Estudantes podem ler mensagens onde são envolvidos.
      // 3. Professores (não-estudantes) podem ler mensagens com disciplina (o app filtra a 'própria').
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == resource.data.sender_id || request.auth.uid == resource.data.receiver_id) ||
        (!exists(/databases/$(database)/documents/students/$(request.auth.uid)) && resource.data.subject != null)
      );
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /student_notes/{noteId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.student_id || 
        isAdmin() ||
        (!exists(/databases/$(database)/documents/students/$(request.auth.uid)) && resource.data.teacher_subject != null)
      );
      allow create: if isAdmin() || (!exists(/databases/$(database)/documents/students/$(request.auth.uid)) && request.resource.data.teacher_subject != null);
      allow update: if isAdmin() || (!exists(/databases/$(database)/documents/students/$(request.auth.uid)) && resource.data.teacher_subject != null);
      allow delete: if isAdmin();
    }

    match /teacher_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && profileId == request.auth.token.email);
    }

    match /bimonthly_exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
